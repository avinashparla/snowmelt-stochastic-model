\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Comparison between MODIS-derived basin-averaged snow fraction and normalized model melt outputs. The inverse relationship demonstrates consistency between modeled melt dynamics and observed snow depletion. Deterministic simulations capture seasonal trends, while stochastic models reproduce short-term variability.}}{14}{}\protected@file@percent }
