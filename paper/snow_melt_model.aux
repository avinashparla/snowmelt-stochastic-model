\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Snowmelt uncertainty derived from Monte Carlo simulation. The shaded region represents the 10-90\% ensemble range, which widens significantly during active melt periods, indicating strong state-dependent variability. The ensemble mean closely follows the deterministic estimate.}}{11}{}\protected@file@percent }
\newlabel{fig:uncertainty}{{3}{11}{}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Distribution of snowmelt values on a logarithmic density scale. The stochastic model exhibits a broader distribution with a pronounced heavy tail, indicating an increased likelihood of extreme melt events compared to the deterministic formulation.}}{11}{}\protected@file@percent }
\newlabel{fig:distribution}{{4}{11}{}{figure.4}{}}
