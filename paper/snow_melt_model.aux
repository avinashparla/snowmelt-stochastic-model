\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Sensitivity of modeled snowmelt to key stochastic parameters. (a) Increasing persistence $\phi $ enhances temporal smoothness and memory in melt dynamics. (b) Increasing jump probability $p$ increases the frequency and magnitude of extreme melt events. The overall seasonal structure remains largely unchanged across parameter values.}}{13}{}\protected@file@percent }
\newlabel{fig:sensitivity}{{5}{13}{}{figure.5}{}}
