\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Temporal evolution of snowmelt for deterministic and stochastic models. The deterministic model produces smooth seasonal melt cycles, while the AR(1) model introduces persistent variability and the temperature-triggered jump model captures intermittent high-magnitude melt events.}}{10}{}\protected@file@percent }
\newlabel{fig:model_comparison}{{2}{10}{}{figure.2}{}}
